@model PurchaseOrderVM

<div class="card">
    <div class="card-body">
        <h2 class="card-title">@(Model.PurchaseOrder.PurchaseOrderId == 0 ? "新增" : "修改")進貨單</h2>
        <form class="py-3 form-group" method="post">
            <input asp-for="PurchaseOrder.PurchaseOrderId" hidden />
            <input asp-for="PurchaseOrder.OrderNumber" hidden />
            <input asp-for="PurchaseOrder.Timeset" value="@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")" hidden />
            @if (Model.PurchaseOrder.PurchaseOrderId != 0)
            {
                <div class="form-group">
                    <label asp-for="PurchaseOrder.OrderNumber"></label>
                    <input asp-for="PurchaseOrder.OrderNumber" type="text" class="form-control" style="color:black" disabled />
                </div>
            }
             <div class="form-group">
                <label asp-for="PurchaseOrder.SupplierId"></label>
                <select asp-for="PurchaseOrder.SupplierId" asp-items="@Model.SupplierList" class="form-select">
                    <option disabled selected>請選擇供應商</option>
                </select>
                <span asp-validation-for="PurchaseOrder.SupplierId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseOrder.SupplierOrderNumber"></label>
                <input asp-for="PurchaseOrder.SupplierOrderNumber" type="text" class="form-control" placeholder="" />
                <span asp-validation-for="PurchaseOrder.SupplierOrderNumber" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseOrder.Date"></label>
                <input asp-for="PurchaseOrder.Date" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="PurchaseOrder.Date" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseOrder.Note"></label>
                <textarea asp-for="PurchaseOrder.Note" type="text" class="form-control"></textarea>
                <span asp-validation-for="PurchaseOrder.Note" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="PurchaseOrder.TotalPrice"></label>
                <input asp-for="PurchaseOrder.TotalPrice" type="number" class="form-control" placeholder="" />
                <span asp-validation-for="PurchaseOrder.TotalPrice" class="text-danger"></span>
            </div>
            <div>
                <button type="submit" class="btn btn-primary btn-fw m-3">確認</button>
                <a asp-area="Purchase" asp-controller="PurchaseOrder" asp-action="Index" class="btn btn-light btn-fw m-3">取消</a>
            </div>
        </form>
    </div>
</div>

@if(Model.PurchaseOrder.PurchaseOrderId != 0)
{
    <div class="card">
        <div class="card-body">
            <form class="py-3 form-group" method="post" asp-area="Purchase" asp-controller="PurchaseOrder" asp-action="CreatePurchaseDetail">
                <input asp-for="PurchaseDetailVM.PurchaseDetail.PurchaseOrderId" value="@Model.PurchaseOrder.PurchaseOrderId" hidden />
                <div class="form-group">
                    <label asp-for="PurchaseDetailVM.PurchaseDetail.ProductId"></label>
                    <select asp-for="PurchaseDetailVM.PurchaseDetail.ProductId" asp-items="@Model.PurchaseDetailVM.ProductList" class="form-select">
                        <option disabled selected>請選擇供應商</option>
                    </select>
                    <span asp-validation-for="PurchaseDetailVM.PurchaseDetail.ProductId" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PurchaseDetailVM.PurchaseDetail.Cost"></label>
                    <input asp-for="PurchaseDetailVM.PurchaseDetail.Cost" type="number" class="form-control" placeholder="" />
                    <span asp-validation-for="PurchaseDetailVM.PurchaseDetail.Cost" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label asp-for="PurchaseDetailVM.PurchaseDetail.Quantity"></label>
                    <input asp-for="PurchaseDetailVM.PurchaseDetail.Quantity" type="number" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="PurchaseDetailVM.PurchaseDetail.Quantity" class="text-danger"></span>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary btn-fw m-3">確認</button>
                </div>
            </form>
        </div>
    </div>
    <div class="card">
        <div class="card-body">
            <div class="table-responsive py-3">
                <table class="table table-bordered" id="tblData">
                    <thead>
                        <tr>
                            <th>NO.</th>
                            <th>商品名稱</th>
                            <th>進貨成本</th>
                            <th>進貨數量</th>
                            <th>小計</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.PurchaseDetailVM.PurchaseDetailList.Count; i++)
                        {
                            var detail = Model.PurchaseDetailVM.PurchaseDetailList.OrderBy(u => u.PurchaseDetailId).ElementAt(i);
                            <tr>
                                <td>@(i + 1)</td>
                                <td>@detail.Product.Name</td>
                                <td>@detail.Cost</td>
                                <td>@detail.Quantity</td>
                                <td>@detail.TotalPrice</td>
                                <td>
                                    <form method="post" asp-asp-area="Purchase" asp-asp-controller="PurchaseOrder" asp-action="DeletePurchaseDetail">
                                        <input name="PurchaseDetailId" value="@detail.PurchaseDetailId" hidden />
                                        <input name="PurchaseOrderId" value="@Model.PurchaseOrder.PurchaseOrderId" hidden />
                                        <button type="submit" class="btn btn-danger">刪除</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}